DirectoryIndex index.html

RewriteEngine On

RewriteRule ^index/?$ / [R=301,L]
RewriteRule ^gallery_list/?$ /galleries [R=301,L]

RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

RewriteCond %{THE_REQUEST} \s/+gallery_list\.html[\s?] [NC]
RewriteRule ^gallery_list\.html$ /galleries [R=301,L]

RewriteCond %{THE_REQUEST} \s/+(.+?)\.html[\s?] [NC]
RewriteRule ^(.+)\.html$ /$1 [R=301,L]

RewriteRule ^home/?$ index.html [NC,L]
RewriteRule ^galleries/?$ gallery_list.html [NC,L]

RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [NC,L]
